{
  "name": "chromactl",
  "version": "0.1.0",
  "type": "module",
  "description": "ChromaDB CLI management tool",
  "bin": {
    "chromactl": "./dist/index.js"
  },
  "scripts": {
    "build": "pnpm typecheck && tsup",
    "build:no-typecheck": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "chalk": "^5.4.1",
    "chromactl": "link:",
    "chromadb": "^3.4.3",
    "commander": "^15.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "eslint": "^9.28.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "engines": {
    "node": ">=22"
  }
}
